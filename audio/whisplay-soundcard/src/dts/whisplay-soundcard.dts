/*
 * Device Tree overlay for Whisplay unified sound card.
 *
 * One machine driver (pisugar,whisplay-soundcard) auto-detects
 * ES8389 (0x10) or WM8960 (0x1a) at probe time.
 *
 * MCLK: ES8389 24.576MHz, WM8960 24.000MHz
 *
 * Uses &i2s which resolves to:
 *   Pi 3/4: bcm2835_i2s
 *   Pi 5:   rp1_i2s0 (via firmware alias)
 */

/dts-v1/;
/plugin/;

/ {
	compatible = "brcm,bcm2835";

	fragment@0 {
		target = <&i2s>;
		__overlay__ {
			status = "okay";
		};
	};

	fragment@1 {
		target-path = "/";
		__overlay__ {
			es8389_mclk: es8389-mclk {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <24576000>;
				clock-output-names = "es8389-mclk";
			};

			wm8960_mclk: wm8960-mclk {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <24000000>;
				clock-output-names = "wm8960-mclk";
			};

			es8389_vddd: es8389-vddd {
				compatible = "regulator-fixed";
				regulator-name = "es8389-vddd";
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-boot-on;
				regulator-always-on;
			};

			es8389_vdda: es8389-vdda {
				compatible = "regulator-fixed";
				regulator-name = "es8389-vdda";
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-boot-on;
				regulator-always-on;
			};
		};
	};

	fragment@2 {
		target = <&i2c1>;
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			codec_es8389: whisplay@10 {
				compatible = "pisugar,whisplay";
				reg = <0x10>;
				#sound-dai-cells = <0>;
				clocks = <&es8389_mclk>;
				clock-names = "mclk";
				vddd-supply = <&es8389_vddd>;
				vdda-supply = <&es8389_vdda>;
				everest,mclk-src = /bits/ 8 <0x40>;
			};

			codec_wm8960: wm8960@1a {
				compatible = "wlf,wm8960";
				reg = <0x1a>;
				#sound-dai-cells = <0>;
				clocks = <&wm8960_mclk>;
				clock-names = "mclk";
				wlf,shared-lrclk;
			};
		};
	};

	/* Single machine driver - auto-detects ES8389 or WM8960 */
	fragment@3 {
		target-path = "/";
		__overlay__ {
			sound {
				compatible = "pisugar,whisplay-soundcard";
				i2s-controller = <&i2s>;
				whisplay,es8389-codec = <&codec_es8389>;
				whisplay,wm8960-codec = <&codec_wm8960>;
				status = "okay";
			};
		};
	};
};
